"""
indexing/build_faiss_http.py
-----------------------------
Builds a separate FAISS index for http.jsonl browsing logs.

Run AFTER build_faiss.py (which handles all other event types).

Usage:
    python indexing/build_faiss_http.py

Environment variables required (set in .env):
    PAGEINDEX_DIR   = path to pageindex_data/ folder
    FAISS_DIR       = path to faiss_index/ folder
    EMBEDDING_MODEL = sentence transformer model name
"""

import os
import sys
import json
import pickle
import numpy as np

sys.path.append(os.path.join(os.path.dirname(__file__), ".."))
from dotenv import load_dotenv
load_dotenv()

from configs.paths import PAGEINDEX_DIR, FAISS_DIR, EMBEDDING_MODEL, check_paths

# ─────────────────────────────────────────────
# VALIDATE
# ─────────────────────────────────────────────
if not check_paths():
    sys.exit(1)

HTTP_JSONL   = os.path.join(PAGEINDEX_DIR, "http.jsonl")
HTTP_INDEX   = os.path.join(FAISS_DIR, "http_events.index")
HTTP_PAGEMAP = os.path.join(FAISS_DIR, "http_page_id_map.pkl")

if not os.path.exists(HTTP_JSONL):
    print(f"ERROR: http.jsonl not found at {HTTP_JSONL}")
    sys.exit(1)

os.makedirs(FAISS_DIR, exist_ok=True)

# ─────────────────────────────────────────────
# CONFIG
# ─────────────────────────────────────────────
BATCH_SIZE = 10000
DIM        = 384

print("=" * 60)
print("Building FAISS index for http.jsonl")
print("=" * 60)
print(f"  Input  : {HTTP_JSONL}")
print(f"  Output : {HTTP_INDEX}")
print(f"  Model  : {EMBEDDING_MODEL}")
print()

# ─────────────────────────────────────────────
# LOAD MODEL
# ─────────────────────────────────────────────
print("Loading embedding model...")
from sentence_transformers import SentenceTransformer
model = SentenceTransformer(EMBEDDING_MODEL)
print(f"  Model loaded!")

# ─────────────────────────────────────────────
# COUNT LINES
# ─────────────────────────────────────────────
print("Counting records...")
total = sum(1 for _ in open(HTTP_JSONL, "r", encoding="utf-8"))
print(f"  Total records: {total:,}")

# ─────────────────────────────────────────────
# BUILD INDEX
# ─────────────────────────────────────────────
import faiss

index      = faiss.IndexFlatIP(DIM)
page_ids   = []
batch_texts = []
batch_pids  = []
processed  = 0

print("\nBuilding FAISS index...")

with open(HTTP_JSONL, "r", encoding="utf-8") as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            rec = json.loads(line)
            text    = rec.get("normalized_text") or rec.get("text", "")
            page_id = rec.get("page_id", "")
            if not text or not page_id:
                continue
            batch_texts.append(text)
            batch_pids.append(page_id)

            if len(batch_texts) >= BATCH_SIZE:
                vecs = model.encode(
                    batch_texts,
                    normalize_embeddings=True,
                    show_progress_bar=False
                ).astype(np.float32)
                index.add(vecs)
                page_ids.extend(batch_pids)
                processed += len(batch_pids)
                batch_texts = []
                batch_pids  = []
                print(f"  Processed {processed:,} / {total:,} records...")

        except Exception:
            continue

# Final batch
if batch_texts:
    vecs = model.encode(
        batch_texts,
        normalize_embeddings=True,
        show_progress_bar=False
    ).astype(np.float32)
    index.add(vecs)
    page_ids.extend(batch_pids)
    processed += len(batch_pids)

print(f"\n  Total indexed: {processed:,} records")

# ─────────────────────────────────────────────
# SAVE
# ─────────────────────────────────────────────
print("\nSaving index...")
faiss.write_index(index, HTTP_INDEX)
with open(HTTP_PAGEMAP, "wb") as f:
    pickle.dump(page_ids, f)

size_gb = os.path.getsize(HTTP_INDEX) / 1024 / 1024 / 1024
print(f"  http_events.index saved ({size_gb:.2f} GB)")
print(f"  http_page_id_map.pkl saved ({len(page_ids):,} entries)")

print("\nDone! HTTP FAISS index built successfully.")